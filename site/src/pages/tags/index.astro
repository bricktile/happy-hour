---
import Base from '../../layouts/Base.astro';
import TagCloud from '../../components/TagCloud.astro';
import { getDB, getAllTags } from '../../lib/db';

const db = getDB(Astro.locals);
const tags = await getAllTags(db);
---

<Base title="Tags - Happy Hour">
  <section class="tags-page">
    <h1>Tags</h1>
    <p class="subtitle">Browse articles by topic. {tags.length} tags total.</p>
    {tags.length > 0 ? (
      <TagCloud tags={tags} />
    ) : (
      <p class="empty">No tags yet. Be the first to publish a tagged article!</p>
    )}
  </section>
</Base>

<style>
  .tags-page {
    padding: 2rem 0 3rem;
  }

  .tags-page h1 {
    margin-top: 0;
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .empty {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
</style>
