---
import NoteLayout from '../../layouts/NoteLayout.astro';
import Recommendations from '../../components/Recommendations.astro';
import { getDB, getArticleWithTags, getRecommendedArticles } from '../../lib/db';

const { user: username, slug } = Astro.params;
const db = getDB(Astro.locals);

const article = await getArticleWithTags(db, username!, slug!);
if (!article) {
  return new Response('Article not found', { status: 404 });
}

const tagIds = article.tags.map(t => t.id);
const recommended = tagIds.length > 0
  ? await getRecommendedArticles(db, article.id, tagIds, 5)
  : [];
---

<NoteLayout title={article.title} author={article.author_username} date={article.published_at} tags={article.tags}>
  <Fragment set:html={article.body_html} />

  {recommended.length > 0 && (
    <Recommendations articles={recommended} />
  )}
</NoteLayout>
