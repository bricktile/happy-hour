---
import Base from '../layouts/Base.astro';
import Leaderboard from '../components/Leaderboard.astro';
import NoteCard from '../components/NoteCard.astro';
import { loadAllNotes, getAllUserStats } from '../lib/notes';

const notes = loadAllNotes();
const allStats = getAllUserStats(notes);
const totalNotes = notes.length;
const totalUsers = allStats.length;
const totalDays = allStats.reduce((sum, s) => sum + s.totalCheckInDays, 0);

const recentNotes = [...notes]
  .filter(n => n.date)
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 12);
---

<Base title="Happy Hour - Learn anything at anytime">
  <section class="hero">
    <h1>Happy Hour</h1>
    <p class="tagline">Learn anything at anytime in one hour.</p>
    <p class="subtitle">
      Git commit = check-in. Push your notes, build your streak.
    </p>
  </section>

  <section class="stats-bar">
    <div class="stat">
      <span class="stat-value">{totalUsers}</span>
      <span class="stat-label">Learners</span>
    </div>
    <div class="stat">
      <span class="stat-value">{totalNotes}</span>
      <span class="stat-label">Notes</span>
    </div>
    <div class="stat">
      <span class="stat-value">{totalDays}</span>
      <span class="stat-label">Check-in Days</span>
    </div>
  </section>

  <Leaderboard stats={allStats} />

  <section class="recent">
    <h2>Recent Notes</h2>
    <div class="notes-grid">
      {recentNotes.map(note => (
        <NoteCard
          title={note.title}
          author={note.author}
          slug={note.slug}
          date={note.date}
        />
      ))}
    </div>
  </section>
</Base>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin: 0;
    color: var(--accent);
  }

  .tagline {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin: 0.5rem 0;
    font-family: var(--font-mono);
  }

  .subtitle {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 0;
  }

  .stats-bar {
    display: flex;
    justify-content: center;
    gap: 3rem;
    padding: 1.5rem 0;
    margin: 1rem 0 2rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-value {
    font-family: var(--font-mono);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--accent);
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .recent {
    margin: 2rem 0 3rem;
  }

  .recent h2 {
    font-size: 1.2rem;
    color: var(--accent);
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
</style>
