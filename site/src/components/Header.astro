---
const user = Astro.locals.user;
---

<header>
  <div class="container header-inner">
    <a href="/" class="logo">
      <span class="prompt">&gt;_</span> Happy Hour
    </a>
    <nav>
      <a href="/">Home</a>
      <a href="/tags">Tags</a>
      <a href="/about">About</a>
      {user ? (
        <a href="/editor" class="nav-action">+ New</a>
        <div class="user-menu">
          <img src={user.avatar_url} alt={user.username} class="avatar" width="24" height="24" />
          <span class="username">{user.username}</span>
          <div class="dropdown">
            <a href={`/${user.username}/`}>My Articles</a>
            <a href="/api/auth/logout">Sign Out</a>
          </div>
        </div>
      ) : (
        <a href="/api/auth/github" class="nav-action login-btn">Sign in with GitHub</a>
      )}
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border);
    background: var(--bg-card);
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 3.5rem;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }

  .logo:hover {
    text-decoration: none;
  }

  .prompt {
    color: var(--accent);
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  nav a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  nav a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .nav-action {
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.8rem;
  }

  .nav-action:hover {
    border-color: var(--accent-dim);
  }

  .login-btn {
    color: var(--accent);
    border-color: var(--accent-dim);
  }

  .user-menu {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }

  .avatar {
    border-radius: 50%;
    border: 1px solid var(--border);
  }

  .username {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text);
  }

  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 0.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 0;
    min-width: 140px;
    z-index: 100;
  }

  .dropdown a {
    display: block;
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
  }

  .user-menu:hover .dropdown {
    display: block;
  }
</style>
